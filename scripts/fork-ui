#!/usr/bin/env python3
"""fork-ui — serve the Void Saga Fork Interview as a local web page.

Layer 1 (Experience) only. Layer 2 (questions) and Layer 3 (engine) are untouched.
Same output as ./scripts/start-fork: answers.md + fork-record.json stub.
"""

import http.server
import json
import os
import re
import shutil
import socketserver
import sys
import urllib.request
import urllib.error
import webbrowser
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
UI_DIR = ROOT / "mvp" / "ui"
INPUT_DIR = ROOT / "mvp" / "input"
RUNS_DIR = ROOT / "mvp" / "runs"
TEMPLATE = ROOT / "mvp" / "templates" / "fork-record.template.json"
LAWS_PATH = ROOT / "mvp" / "laws" / "bab00-laws.json"
FORK_POINTS_PATH = ROOT / "mvp" / "genesis" / "fork-points.json"

BAB00 = ROOT / "Bab 00 — Menatap Akhir Era dari Balik.md"
INDEX_HTML = UI_DIR / "index.html"

PORT = 3720

# Add mvp to path so we can import check_fork
sys.path.insert(0, str(ROOT / "mvp" / "checker"))
try:
    from check_fork import check_fork as run_checker
except ImportError:
    run_checker = None


class ThreadingServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    """Handle requests in threads so a refresh doesn't block."""
    daemon_threads = True


class ForkHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        # Quiet logging
        sys.stderr.write(f"  {args[0]}\n")

    def do_GET(self):
        try:
            self._do_GET()
        except Exception as e:
            self.send_error(500, str(e))

    def _do_GET(self):
        if self.path in ("/", "/index.html"):
            self._serve_index()
        elif self.path == "/api/bab00":
            self._serve_bab00()
        elif self.path == "/api/gallery":
            self._handle_gallery()
        elif self.path == "/favicon.ico":
            self.send_error(204)  # No content — stop browser nagging
        else:
            # Try static files from UI dir
            filepath = UI_DIR / self.path.lstrip("/")
            if filepath.exists() and filepath.is_file():
                self._serve_file(filepath)
            else:
                self.send_error(404)

    def do_POST(self):
        try:
            self._do_POST()
        except Exception as e:
            self.send_error(500, str(e))

    def _do_POST(self):
        if self.path == "/api/save":
            self._handle_save()
        elif self.path == "/api/translate":
            self._handle_translate()
        elif self.path == "/api/check":
            self._handle_check()
        elif self.path == "/api/generate-scene":
            self._handle_generate_scene()
        else:
            self.send_error(404)

    def _serve_file(self, path, content_type=None):
        if content_type is None:
            ext = path.suffix.lower()
            ct_map = {
                ".html": "text/html; charset=utf-8",
                ".css": "text/css; charset=utf-8",
                ".js": "application/javascript; charset=utf-8",
                ".json": "application/json",
                ".md": "text/markdown; charset=utf-8",
                ".txt": "text/plain; charset=utf-8",
                ".png": "image/png",
                ".svg": "image/svg+xml",
            }
            content_type = ct_map.get(ext, "application/octet-stream")

        try:
            data = path.read_bytes()
            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", len(data))
            self.end_headers()
            self.wfile.write(data)
        except Exception:
            self.send_error(500)

    def _serve_index(self):
        """Serve index.html with Bab 00 content injected inline (no fetch needed)."""
        try:
            import html as html_mod
            html = INDEX_HTML.read_text()
            bab00 = BAB00.read_text()
            # Process: terminal-line blocks (starting with >) become styled HTML
            processed = self._process_bab00(bab00)
            html = html.replace("<!--BAB00_SOURCE-->", processed)
            data = html.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", len(data))
            self.send_header("Cache-Control", "no-store, no-cache, must-revalidate")
            self.end_headers()
            self.wfile.write(data)
        except Exception:
            self.send_error(500)

    def _process_bab00(self, text):
        """Convert >-prefixed lines into terminal blocks. Everything else is HTML-escaped text."""
        import html as html_mod
        lines = text.split('\n')
        out = []
        term_buf = []
        text_buf = []

        def flush_text():
            nonlocal text_buf
            if text_buf:
                escaped = html_mod.escape('\n'.join(text_buf))
                out.append('<div class="genesis-text">' + escaped.replace('\n', '<br>') + '</div>')
                text_buf = []

        def flush_term():
            nonlocal term_buf
            if term_buf:
                out.append('<div class="term-block">')
                for tline in term_buf:
                    # Strip the leading ">"
                    content = tline[1:] if tline.startswith('>') else tline
                    # Remove one leading space if present
                    if content.startswith(' '):
                        content = content[1:]
                    if content.strip() == '':
                        # Blank line inside term block
                        out.append('<span class="term-line term-blank">&nbsp;</span>')
                    else:
                        content_esc = html_mod.escape(content)
                        out.append(f'<span class="term-line"><span class="prompt">▸</span>{content_esc}</span>')
                out.append('</div>')
                term_buf = []

        for line in lines:
            stripped = line.lstrip(' ')
            if stripped.startswith('>'):
                # Any line starting with > is a term line (including blank >)
                flush_text()
                term_buf.append(line)
            else:
                flush_term()
                text_buf.append(line)

        flush_term()
        flush_text()

        return '\n'.join(out)

    def _serve_bab00(self):
        try:
            text = BAB00.read_text()
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", len(text.encode("utf-8")))
            self.end_headers()
            self.wfile.write(text.encode("utf-8"))
        except Exception:
            self.send_error(500, "Cannot read bab-00.md")

    def _handle_save(self):
        try:
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            data = json.loads(body)

            name = data.get("name", "anon")
            content = data.get("content", "")

            # Slugify name (same logic as start-fork script)
            import re
            slug = name.lower()
            slug = re.sub(r'[^a-z0-9]+', '-', slug)
            slug = slug.strip('-')
            if not slug:
                slug = "anon"

            run_dir = RUNS_DIR / slug
            run_dir.mkdir(parents=True, exist_ok=True)

            # Save answers.md
            answers_path = run_dir / "answers.md"
            answers_path.write_text(content)

            # Copy fork-record template if not already present
            fork_path = run_dir / "fork-record.json"
            if not fork_path.exists():
                shutil.copy2(TEMPLATE, fork_path)

            # Save interview.json — structured machine-readable interview data
            interview = self._build_interview(name, slug, content)
            interview_path = run_dir / "interview.json"
            interview_path.write_text(json.dumps(interview, indent=2, ensure_ascii=False))

            resp = {"ok": True, "run_dir": str(run_dir.relative_to(ROOT))}
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps(resp).encode("utf-8"))

        except Exception as e:
            resp = {"ok": False, "error": str(e)}
            self.send_response(500)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps(resp).encode("utf-8"))

    def _handle_translate(self):
        """Read answers.md, translate to fork-record.json, run checker, return verdict."""
        try:
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            req = json.loads(body)
            name = req.get("name", "anon")
            slug = self._slugify(name)
            run_dir = RUNS_DIR / slug
            answers_path = run_dir / "answers.md"

            if not answers_path.exists():
                self._json_resp(404, {"ok": False, "error": f"answers.md not found for {name}. Run interview first."})
                return

            # Parse answers
            answers = self._parse_answers(answers_path.read_text())

            # Load reference data
            fork_points = json.loads(FORK_POINTS_PATH.read_text())
            laws = json.loads(LAWS_PATH.read_text())
            fp_index = {fp["fork_point_id"]: fp for fp in fork_points}
            law_index = {l["law_id"]: l for l in laws}

            # Determine fork point from Q1
            q1 = answers.get("q1", "").lower()
            if "a" in q1[:1] or "bug janggal" in q1:
                fp_id = "fp-001"
            elif "c" in q1[:1] or "genesis error" in q1:
                fp_id = "fp-003"
            else:
                fp_id = "fp-002"  # default to Folder Error

            fp = fp_index.get(fp_id, fork_points[0])
            affected_laws = fp.get("affected_laws", [])

            # Build fork record
            violations = self._detect_violations(answers, affected_laws, law_index)
            # Merge detected violation laws into touched_laws
            all_touched = list(set(affected_laws + [v["law_id"] for v in violations]))

            fork = {
                "fork_id": f"fork-{slug}-01",
                "parent_node": "bab00",
                "fork_point": fp_id,
                "title": self._make_title(answers.get("q2", "")),
                "title_id": self._make_title_id(answers.get("q2", "")),
                "premise_id": answers.get("q2", ""),
                "change_id": answers.get("q3", ""),
                "immediate_effect_id": answers.get("q6", ""),
                "internal_summary_en": self._build_summary(answers, fp),
                "participants": ["GUA", "LO"],
                "touched_laws": all_touched,
                "violations": violations,
                "lineage": self._build_lineage(answers, fp, fp_id),
                "price": self._build_price(answers, all_touched, law_index),
                "verdict": "",
                "status": "draft"
            }

            # Save fork record
            fork_path = run_dir / "fork-record.json"
            fork_path.write_text(json.dumps(fork, indent=2, ensure_ascii=False))

            # Run checker
            result = None
            if run_checker:
                try:
                    result = run_checker(str(fork_path), laws=str(LAWS_PATH), verbose=False)
                except Exception as e:
                    result = {"verdict": "UNKNOWN", "reason": f"Checker error: {e}", "status": "error"}

            resp = {
                "ok": True,
                "fork_id": fork["fork_id"],
                "fork_point": fp_id,
                "fork_point_label": fp.get("label", ""),
                "title": fork["title"],
                "verdict": result.get("verdict", "UNKNOWN") if result else "UNKNOWN",
                "status": result.get("status", "unknown") if result else "unknown",
                "reason": result.get("reason", "") if result else "",
                "touched_laws": result.get("touched_laws_detail", []) if result else [],
                "prices": result.get("prices") if result else None,
                "blocked_by": result.get("blocked_by") if result else None,
                "total_laws_touched": result.get("total_laws_touched", 0) if result else 0,
                "total_violations": result.get("total_violations", 0) if result else 0,
            }
            self._json_resp(200, resp)

        except Exception as e:
            import traceback
            self._json_resp(500, {"ok": False, "error": str(e), "trace": traceback.format_exc()})

    def _handle_check(self):
        """Run checker on an existing fork-record.json and return verdict."""
        try:
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            req = json.loads(body)
            name = req.get("name", "anon")
            slug = self._slugify(name)
            fork_path = RUNS_DIR / slug / "fork-record.json"

            if not fork_path.exists():
                self._json_resp(404, {"ok": False, "error": f"fork-record.json not found for {name}"})
                return

            if not run_checker:
                self._json_resp(500, {"ok": False, "error": "Checker module not available"})
                return

            result = run_checker(str(fork_path), laws=str(LAWS_PATH), verbose=False)

            resp = {
                "ok": True,
                "verdict": result.get("verdict", "UNKNOWN"),
                "status": result.get("status", "unknown"),
                "reason": result.get("reason", ""),
                "touched_laws": result.get("touched_laws_detail", []),
                "prices": result.get("prices"),
                "blocked_by": result.get("blocked_by"),
                "total_laws_touched": result.get("total_laws_touched", 0),
                "total_violations": result.get("total_violations", 0),
            }
            self._json_resp(200, resp)

        except Exception as e:
            self._json_resp(500, {"ok": False, "error": str(e)})

    # ── Translation helpers ────────────────────────────

    def _slugify(self, name):
        slug = name.lower()
        slug = re.sub(r'[^a-z0-9]+', '-', slug)
        slug = slug.strip('-')
        return slug or "anon"

    def _parse_answers(self, text):
        """Parse answers.md into {q1..q7} dict."""
        answers = {}
        pattern = r'## Q(\d)\. .+?\n(.+?)(?=\n## Q|\Z)'
        for m in re.finditer(pattern, text, re.DOTALL):
            qnum = m.group(1)
            ans = m.group(2).strip()
            answers[f"q{qnum}"] = ans
        return answers

    def _make_title(self, q2):
        """Make a short English title from Q2 answer."""
        t = q2.strip()
        if len(t) > 80:
            t = t[:77] + "..."
        return t or "Untitled Fork"

    def _make_title_id(self, q2):
        """Make a short Indonesian title from Q2 answer."""
        return self._make_title(q2)

    def _build_summary(self, answers, fp):
        """Build internal_summary_en from all answers."""
        q1 = answers.get("q1", "")
        q2 = answers.get("q2", "")
        q3 = answers.get("q3", "")
        q4 = answers.get("q4", "")
        q5 = answers.get("q5", "")
        q6 = answers.get("q6", "")
        q7 = answers.get("q7", "")
        return (
            f"At {fp.get('label', 'the fork point')} ({fp.get('sub_chapter', '')}): "
            f"{q2} Character action: {q3}. Stakes: {q4}. "
            f"Duration: {q5}. Immediate effect: {q6}. "
            f"Survives/breaks: {q7}"
        )

    def _build_lineage(self, answers, fp, fp_id):
        """Build lineage block from answers and fork point data."""
        q2 = answers.get("q2", "")
        q5 = answers.get("q5", "")
        q7 = answers.get("q7", "")

        # Parse Q7 into survives/breaks list
        effects = [s.strip() for s in q7.replace("SURVIVES:", "SURVIVES:").split("\n") if s.strip()]
        if not effects:
            effects = [q7] if q7 else ["Uncertain — downstream effects not specified."]

        fork_point_labels = {
            "fp-001": "00:03 — Bug Janggal",
            "fp-002": "00:07 — Folder Error (Independent Sync)",
            "fp-003": "00:08 — Genesis Error (The Birth of VoidOS)",
        }

        return {
            "forked_from": "bab00",
            "forked_at": fork_point_labels.get(fp_id, fp.get("sub_chapter", "")),
            "canon_moment": fp.get("moment", ""),
            "divergence": q2,
            "downstream_effects": effects,
        }

    def _detect_violations(self, answers, affected_laws, law_index):
        """Rule-based violation detection from answer text. Checks all 7 laws."""
        violations = []
        all_text = " ".join(answers.values()).lower()

        # Simple keyword-based detection per law
        patterns = {
            "law-001": {"keywords": ["konfrontasi", "hadapi langsung", "confront"], "desc": "GUA may be forced into confrontation without a system buffer."},
            "law-002": {"keywords": ["gak butuh lo", "gak perlu lo", "tanpa lo", "remove lo", "removed", "unnecessary", "pergi dari"], "desc": "LO's stabilizing role may be diminished or removed."},
            "law-003": {"keywords": ["paksa", "dipaksa", "dipaksakan", "tanpa izin", "tanpa consent", "force", "override", "tanpa persetujuan"], "desc": "VoidOS/genesis may be forced without consent."},
            "law-004": {"keywords": ["tanpa nama", "gak dinamain", "unnamed"], "desc": "Naming may be avoided, denying the consequence."},
            "law-005": {"keywords": ["gak ada efek", "gak berubah", "nothing changes", "no ripple", "no downstream", "tidak mengubah"], "desc": "Origin change may not account for downstream propagation."},
            "law-006": {"keywords": ["gak sinkron", "ngga nyambung", "gak nyambung", "disengaja", "direkayasa", "dikoordinasi", "engineered", "coordinated", "dipasangkan"], "desc": "The GUA-LO sync may be forced or externally coordinated."},
            "law-007": {"keywords": ["diabaikan", "diacuhkan", "dismiss", "dianggap sepele", "kebetulan", "coincidence", "gak penting", "trivial", "not an error", "bukan error", "keberuntungan", "cuma masalah sepele", "mengacuhkan", "ngga ngeh", "cuek"], "desc": "An error that should become foundation is dismissed as coincidence or fixed."},
        }

        # Check ALL laws, not just affected ones
        for law_id, p in patterns.items():
            if any(kw in all_text for kw in p["keywords"]):
                law = law_index.get(law_id, {})
                # Only flag as violation if the law is block_on_violate or price_on_violate
                if law.get("block_on_violate") or law.get("price_on_violate"):
                    violations.append({
                        "law_id": law_id,
                        "severity": "medium",
                        "description": f"Auto-detected: {p['desc']} (based on keyword match in interview answers). Review required by Archivist."
                    })

        return violations

    def _build_price(self, answers, affected_laws, law_index):
        """Build price block if any price_on_violate laws are affected."""
        price_laws = []
        for law_id in affected_laws:
            law = law_index.get(law_id, {})
            if law.get("price_on_violate") and not law.get("block_on_violate"):
                price_laws.append(law["name"])

        if not price_laws:
            return None

        q5 = answers.get("q5", "")
        return {
            "type": "narrative_cost",
            "description": f"This fork touches laws that carry price: {', '.join(price_laws)}. Duration of change: {q5}. The Archivist should review and specify exact payment.",
            "affected_nodes": [],
        }

    # ── Interview JSON builder ────────────────────
    def _build_interview(self, name, slug, answers_text):
        """Build structured interview.json from answers.md."""
        answers = self._parse_answers(answers_text)
        q1 = answers.get("q1", "")
        q2 = answers.get("q2", "")
        q3 = answers.get("q3", "")
        q4 = answers.get("q4", "")
        q5 = answers.get("q5", "")
        q6 = answers.get("q6", "")
        q7 = answers.get("q7", "")

        # Determine fork point from Q1
        q1_lower = q1.lower()
        if "a" in q1_lower[:2] or "bug janggal" in q1_lower:
            fp_id = "fp-001"
            segment = "00:03"
        elif "c" in q1_lower[:2] or "genesis error" in q1_lower:
            fp_id = "fp-003"
            segment = "00:08"
        else:
            fp_id = "fp-002"
            segment = "00:07"

        # Extract introduced entities (capitalized unknown names)
        all_answers = " ".join(answers.values())
        introduced = self._extract_entities(all_answers)

        return {
            "writer": name,
            "slug": slug,
            "created_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
            "target_node": "bab00",
            "target_segment": segment,
            "fork_point_id": fp_id,
            "answers": {
                "chosen_moment": q1,
                "what_if": q2,
                "character_action": q3,
                "stakes": q4,
                "duration": q5,
                "immediate_consequence": q6,
                "survives_breaks": q7,
            },
            "introduced_entities": introduced,
        }

    def _extract_entities(self, text):
        """Extract capitalized names not in the known common set."""
        known = {
            "GUA", "LO", "MANAGER", "NOVI", "BAB", "VOID", "VOIDOS", "JIRA", "SLACK",
            "GIT", "API", "EOD", "PR", "DM", "PM", "ON", "TRACK", "SYSTEM", "BOOT",
            "ERROR", "WARNING", "PASSED", "APPROVED", "RESOLVED", "COLLABORATED",
            "DETECTED", "MONITOR", "OPERATIONAL", "UNDEFINED", "LOCAL", "ONLY",
            "UNTRACKED", "END", "DAY", "ZERO", "ORIGIN", "TOTAL", "MINOR",
            "SEVERITY", "ACTION", "SPRINT", "WEEK", "BURNDOWN", "JANGKAL",
            "FIRST", "CONTACT", "SYNC", "GENESIS", "FOLDER", "STEALTH", "PANTRY",
            "STANDUP", "DAILY", "PROJECT", "PROTOCOL", "RELATIONSHIP",
        }
        entities = []
        seen = set()
        for word in re.findall(r'\b([A-Z][A-Z]{2,})\b', text):
            if word not in known and word not in seen:
                seen.add(word)
                entities.append({
                    "name": word,
                    "type": "character",
                    "source_answer": "duration/immediate_consequence/survives_breaks",
                    "user_declared": True,
                    "status": "unvalidated",
                })
        return entities[:5]  # Cap at 5

    # ── Scene Generation ────────────────────────────
    # TODO: replace client-supplied API keys with secure server-side credential
    # handling before public launch.

    def _handle_generate_scene(self):
        """POST /api/generate-scene — generate one fork scene via AI provider."""
        try:
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            req = json.loads(body)
            name = req.get("name", "anon")
            provider = req.get("provider", "").lower()
            model = req.get("model", "")
            api_key = (req.get("apiKey") or "").strip()

            if not provider or not model or not api_key:
                self._json_resp(400, {"ok": False, "error": "Provider, model, and API key are required."})
                return

            slug = self._slugify(name)
            run_dir = RUNS_DIR / slug
            answers_path = run_dir / "answers.md"
            fork_path = run_dir / "fork-record.json"

            if not answers_path.exists():
                self._json_resp(404, {"ok": False, "error": f"answers.md not found for {name}. Run the interview first."})
                return
            if not fork_path.exists():
                self._json_resp(404, {"ok": False, "error": f"fork-record.json not found for {name}. Translate first."})
                return

            fork_record = json.loads(fork_path.read_text())
            verdict = fork_record.get("verdict", "")

            # Check verdict with the real checker if available
            actual_verdict = verdict
            if run_checker:
                try:
                    result = run_checker(str(fork_path), laws=str(LAWS_PATH), verbose=False)
                    actual_verdict = result.get("verdict", verdict)
                except Exception:
                    actual_verdict = verdict

            if actual_verdict == "BLOCKED" or verdict == "BLOCKED":
                self._json_resp(403, {"ok": False, "error": "BLOCKED forks cannot generate scenes. This fork violates a hard-block law and cannot continue."})
                return

            # Load interview.json if available
            interview = {}
            interview_path = run_dir / "interview.json"
            if interview_path.exists():
                try:
                    interview = json.loads(interview_path.read_text())
                except Exception:
                    pass

            # Build scene prompt packet with all context
            packet = self._build_prompt_packet(name, slug, fork_record, interview, actual_verdict)
            packet_path = run_dir / "scene-prompt-packet.json"
            packet_path.write_text(json.dumps(packet, indent=2, ensure_ascii=False))

            # Build prompt from packet
            prompt = self._build_generation_prompt(packet)

            # Call provider (API key never logged or persisted)
            try:
                scene_md = self._call_provider(provider, model, api_key, prompt)
            except Exception as e:
                err_msg = str(e)
                if api_key and len(api_key) > 4:
                    err_msg = err_msg.replace(api_key, "[REDACTED]")
                self._json_resp(500, {"ok": False, "error": f"Provider error: {err_msg}"})
                return

            # Save raw draft
            draft_path = run_dir / "fork-scene.draft.md"
            draft_path.write_text(scene_md)

            # Run scene gate validator
            gate_result = {"overall": "WARNING", "checks": [], "issues": ["Scene Gate not run — checker unavailable."]}
            scene_checker = ROOT / "mvp" / "checker" / "check_scene.py"
            if scene_checker.exists():
                try:
                    import subprocess
                    proc = subprocess.run(
                        [sys.executable, str(scene_checker), str(draft_path), "--packet", str(packet_path)],
                        capture_output=True, text=True, timeout=30,
                    )
                    gate_result = json.loads(proc.stdout)
                except Exception as e:
                    gate_result = {"overall": "WARNING", "checks": [], "issues": [f"Scene Gate error: {e}"]}

            # Save gate result
            gate_path = run_dir / "scene-gate.json"
            gate_path.write_text(json.dumps(gate_result, indent=2, ensure_ascii=False))

            # Determine final scene
            overall = gate_result.get("overall", "WARNING")
            final_scene_written = False
            if overall == "FAIL":
                # Draft only — do not write fork-scene.md
                pass
            else:
                # PASS or WARNING: write final scene
                scene_path = run_dir / "fork-scene.md"
                scene_path.write_text(scene_md)
                final_scene_written = True

            # Save metadata
            gallery_id = f"{slug}-{int(datetime.now(timezone.utc).timestamp())}"
            meta = {
                "writer": name, "slug": slug,
                "generated_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
                "provider": provider, "model": model,
                "verdict": actual_verdict,
                "scene_gate": overall,
                "fork_id": fork_record.get("fork_id", ""),
                "fork_point": fork_record.get("fork_point", ""),
                "scene_path": str((run_dir / "fork-scene.md").relative_to(ROOT)) if final_scene_written else "",
                "draft_path": str(draft_path.relative_to(ROOT)),
                "gallery_id": gallery_id,
            }
            meta_path = run_dir / "scene-meta.json"
            meta_path.write_text(json.dumps(meta, indent=2, ensure_ascii=False))

            resp = {
                "ok": True,
                "scene_markdown": scene_md,
                "provider": provider, "model": model,
                "verdict": actual_verdict,
                "gallery_id": gallery_id,
                "scene_gate": gate_result,
                "final_scene_written": final_scene_written,
                "scene_path": str((run_dir / "fork-scene.md").relative_to(ROOT)) if final_scene_written else "",
                "draft_path": str(draft_path.relative_to(ROOT)),
            }
            self._json_resp(200, resp)

        except Exception as e:
            self._json_resp(500, {"ok": False, "error": str(e)})

    def _handle_gallery(self):
        """GET /api/gallery — list all generated fork scenes."""
        try:
            entries = []
            if RUNS_DIR.exists():
                for run_dir in sorted(RUNS_DIR.iterdir(), reverse=True):
                    if not run_dir.is_dir():
                        continue
                    meta_path = run_dir / "scene-meta.json"
                    # Accept either fork-scene.md (final) or fork-scene.draft.md (draft only)
                    scene_path = run_dir / "fork-scene.md"
                    draft_path = run_dir / "fork-scene.draft.md"
                    if not meta_path.exists():
                        continue
                    if not scene_path.exists() and not draft_path.exists():
                        continue
                    read_path = scene_path if scene_path.exists() else draft_path
                    try:
                        meta = json.loads(meta_path.read_text())
                        # Skip FAIL drafts — they were rejected by Scene Gate
                        if meta.get("scene_gate") == "FAIL" and not scene_path.exists():
                            continue
                        # Include a short excerpt
                        scene_text = read_path.read_text()
                        excerpt = scene_text[:200].replace("\n", " ").strip()
                        if len(scene_text) > 200:
                            excerpt += "…"
                        meta["excerpt"] = excerpt
                        meta["scene_text"] = scene_text
                        meta["has_final"] = scene_path.exists()
                        entries.append(meta)
                    except Exception:
                        continue
            self._json_resp(200, {"ok": True, "entries": entries})
        except Exception as e:
            self._json_resp(500, {"ok": False, "error": str(e)})

    # ── Provider calling ────────────────────────────

    def _call_provider(self, provider, model, api_key, prompt):
        """Call the selected AI provider and return generated markdown text."""
        if provider == "claude":
            return self._call_claude(model, api_key, prompt)
        elif provider == "openai":
            return self._call_openai(model, api_key, prompt)
        elif provider == "deepseek":
            return self._call_deepseek(model, api_key, prompt)
        else:
            raise ValueError(f"Unknown provider: {provider}")

    def _call_claude(self, model, api_key, prompt):
        """Call Anthropic Claude API."""
        url = "https://api.anthropic.com/v1/messages"
        body = json.dumps({
            "model": model,
            "max_tokens": 4096,
            "temperature": 0.8,
            "messages": [{"role": "user", "content": prompt}],
        }).encode("utf-8")
        req = urllib.request.Request(url, data=body)
        req.add_header("Content-Type", "application/json")
        req.add_header("x-api-key", api_key)
        req.add_header("anthropic-version", "2023-06-01")
        try:
            with urllib.request.urlopen(req, timeout=120) as resp:
                data = json.loads(resp.read().decode("utf-8"))
                content = data.get("content", [])
                if isinstance(content, list):
                    return "".join(b.get("text", "") for b in content if b.get("type") == "text")
                return str(content)
        except urllib.error.HTTPError as e:
            msg = e.read().decode("utf-8", errors="replace")[:500]
            raise RuntimeError(f"Claude API error {e.code}: {msg}")

    def _call_openai(self, model, api_key, prompt):
        """Call OpenAI API."""
        url = "https://api.openai.com/v1/chat/completions"
        body = json.dumps({
            "model": model,
            "max_tokens": 4096,
            "temperature": 0.8,
            "messages": [{"role": "user", "content": prompt}],
        }).encode("utf-8")
        req = urllib.request.Request(url, data=body)
        req.add_header("Content-Type", "application/json")
        req.add_header("Authorization", f"Bearer {api_key}")
        try:
            with urllib.request.urlopen(req, timeout=120) as resp:
                data = json.loads(resp.read().decode("utf-8"))
                return data["choices"][0]["message"]["content"]
        except urllib.error.HTTPError as e:
            msg = e.read().decode("utf-8", errors="replace")[:500]
            raise RuntimeError(f"OpenAI API error {e.code}: {msg}")

    def _call_deepseek(self, model, api_key, prompt):
        """Call DeepSeek API (OpenAI-compatible)."""
        url = "https://api.deepseek.com/v1/chat/completions"
        body = json.dumps({
            "model": model,
            "max_tokens": 4096,
            "temperature": 0.8,
            "messages": [{"role": "user", "content": prompt}],
        }).encode("utf-8")
        req = urllib.request.Request(url, data=body)
        req.add_header("Content-Type", "application/json")
        req.add_header("Authorization", f"Bearer {api_key}")
        try:
            with urllib.request.urlopen(req, timeout=120) as resp:
                data = json.loads(resp.read().decode("utf-8"))
                return data["choices"][0]["message"]["content"]
        except urllib.error.HTTPError as e:
            msg = e.read().decode("utf-8", errors="replace")[:500]
            raise RuntimeError(f"DeepSeek API error {e.code}: {msg}")

    # ── Prompt builder ──────────────────────────────

    def _build_prompt_packet(self, name, slug, fork_record, interview, verdict):
        """Build the scene prompt packet with all context artifacts."""
        fp_id = fork_record.get("fork_point", interview.get("fork_point_id", "fp-001"))
        target_segment = interview.get("target_segment", "00:03")

        # Load segment-fork-map
        segment_ctx = {}
        seg_map_path = ROOT / "mvp" / "genesis" / "segment-fork-map.json"
        if seg_map_path.exists():
            seg_map = json.loads(seg_map_path.read_text())
            for seg in seg_map.get("segments", []):
                if seg.get("segment_id") == target_segment:
                    segment_ctx = seg
                    break

        # Load voice contract
        voice = {}
        voice_path = ROOT / "mvp" / "style" / "bab00-voice-contract.json"
        if voice_path.exists():
            voice = json.loads(voice_path.read_text())

        # Allowed entities
        introduced = interview.get("introduced_entities", [])
        introduced_names = [e["name"] for e in introduced]
        allowed_entities = ["GUA", "LO", "MANAGER"] + introduced_names

        # Laws touched
        laws_touched = fork_record.get("touched_laws", [])
        if not laws_touched and segment_ctx:
            laws_touched = segment_ctx.get("likely_laws", [])

        # Generation constraints from segment
        constraints = []
        if segment_ctx:
            constraints = segment_ctx.get("danger_zones", [])[:3]
            constraints = [f"AVOID: {dz}" for dz in constraints]

        # Voice constraints
        if voice:
            for rule in voice.get("required", [])[:4]:
                constraints.append(f"REQUIRED: {rule}")
            for rule in voice.get("forbidden", [])[:4]:
                constraints.append(f"FORBIDDEN: {rule}")

        return {
            "writer": name,
            "slug": slug,
            "target_node": "bab00",
            "target_segment": target_segment,
            "segment_context": segment_ctx,
            "fork_record": fork_record,
            "interview": interview,
            "verdict": verdict,
            "laws_touched": laws_touched,
            "allowed_entities": allowed_entities,
            "voice_contract": voice,
            "generation_constraints": constraints,
        }

    def _build_generation_prompt(self, packet):
        """Build the AI generation prompt from the prompt packet."""
        fork_record = packet.get("fork_record", {})
        interview = packet.get("interview", {})
        verdict = packet.get("verdict", "VALID_FORK")
        segment_ctx = packet.get("segment_context", {})
        constraints = packet.get("generation_constraints", [])
        allowed = packet.get("allowed_entities", ["GUA", "LO", "MANAGER"])
        voice = packet.get("voice_contract", {})
        target_segment = packet.get("target_segment", "00:03")

        title = fork_record.get("title", "Untitled Fork")
        divergence = fork_record.get("lineage", {}).get("divergence", "")
        premise_id = fork_record.get("premise_id", "")
        price = fork_record.get("price") or {}
        answers = interview.get("answers", {})
        introduced = interview.get("introduced_entities", [])

        verdict_guidance = {
            "PASS": "This fork is canon-compatible. Keep the canon mostly intact — show the subtle shift, not a rewrite.",
            "VALID_FORK": "This fork is a legal branch. Make the difference visible but consistent with Bab 00 rules.",
            "PRICE_REQUIRED": "CRITICAL: This fork carries narrative cost. The scene MUST include one concrete, specific cost that alters behavior, artifact, system output, or downstream condition. Not just mention 'price' — show the cost as a tangible change: a log that now parses wrong, a timestamp that drifts further, a system that interprets text as code, a file that corrupts in a meaningful way. The cost should feel small and specific, not abstract.",
        }

        segment_must = segment_ctx.get("must_preserve", [])
        segment_danger = segment_ctx.get("danger_zones", [])
        segment_label = segment_ctx.get("label", target_segment)

        # Build constraints text
        constraint_text = "\n".join(f"- {c}" for c in constraints[:12])

        # Introduced entity guidance
        intro_text = ""
        if introduced:
            names = [e["name"] for e in introduced]
            intro_text = f"\nIntroduced entity: {', '.join(names)}. Keep them scoped to the fork record — do not let them dominate unless the fork requires it."

        # Segment anchor text
        segment_text = f"Target segment: {target_segment} ({segment_label})"
        if segment_must:
            segment_text += f"\nMust preserve: {'; '.join(segment_must[:4])}"

        prompt = f"""You are writing a draft fork scene, not canon. The checker is the authority — you do not overrule it. Follow the Fork Record exactly. Follow the target segment anchor. Follow the Bab 00 Voice Contract.

FORK RECORD:
- Fork: {title}
- Premise: {premise_id}
- Divergence: {divergence}
- Verdict: {verdict}
- {verdict_guidance.get(verdict, verdict_guidance['VALID_FORK'])}
{intro_text}

SEGMENT ANCHOR:
{segment_text}

VOICE CONTRACT (Bab 00 Office Anomaly):
- Use first-person GUA narration: 'gua' and 'lo' naturally.
- Keep paragraphs short, often 1-3 lines. Fragmented rhythm. Negative space.
- Use office/tooling artifacts: logs, Slack, Jira, terminal, code, timestamps, cursor.
- ARTIFACT-FIRST: Let logs, cursors, timestamps, code, file diffs, Slack pauses carry the meaning. Do NOT explain what the reader can infer from artifacts. Avoid sentences like 'Gua paham bahwa...' or 'Tapi harganya adalah...' — show the artifact, then move on.
- LO IS NOT EXPOSITION: Sync happens with few words, often none. Slack exchanges are sparse — single lines, not paragraphs. LO does not explain the situation to GUA or the reader.
- Anomaly must feel small before it feels cosmic. Bab 00 is cold and strange, not warm and explanatory.
- Show emotion through cursor stillness, typing pauses, what is NOT said — not through internal monologue.
- Do NOT write in third-person. Do NOT use 'aku'/'saya' for GUA.
- Do NOT invent prior relationship ('bertahun-tahun', 'sudah kenal lama') unless fork record explicitly permits.
- The generated scene should feel like one segment/fork moment — not a full chapter.

CONSTRAINTS:
{constraint_text}

INTERVIEW CONTEXT:
{json.dumps(answers, ensure_ascii=False, indent=1)[:1500]}

WRITING RULES:
1. Write ONLY the first scene of this fork. One scene. Target 500-900 words. Quality over length.
2. Write in Indonesian (Bahasa Indonesia), with occasional English for technical terms.
3. Output markdown prose only. No meta-commentary. No "as an AI".
4. Allowed characters: {', '.join(allowed)}.

Write the first scene now."""
        return prompt

    def _json_resp(self, code, data):
        """Send a JSON response."""
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.end_headers()
        self.wfile.write(json.dumps(data, ensure_ascii=False).encode("utf-8"))


def main():
    # Verify required files
    if not BAB00.exists():
        print(f"ERROR: {BAB00} not found")
        sys.exit(1)
    if not INDEX_HTML.exists():
        print(f"ERROR: {INDEX_HTML} not found")
        sys.exit(1)
    if not TEMPLATE.exists():
        print(f"ERROR: {TEMPLATE} not found")
        sys.exit(1)

    # Allow immediate rebind after crash
    socketserver.TCPServer.allow_reuse_address = True

    try:
        server = ThreadingServer(("localhost", PORT), ForkHandler)
    except OSError as e:
        if "Address already in use" in str(e):
            print(f"\n  Port {PORT} masih dipakai proses lain.")
            print(f"  Coba:  lsof -ti :{PORT} | xargs kill")
            sys.exit(1)
        raise

    url = f"http://localhost:{PORT}"
    print()
    print("╔══════════════════════════════════════════════════════════╗")
    print("║  VOID SAGA — Fork Interview                             ║")
    print("║  Genesis Node: Bab 00                                   ║")
    print("║                                                        ║")
    print(f"║  Open: {url:<44} ║")
    print("║  Press Ctrl+C to stop                                   ║")
    print("╚══════════════════════════════════════════════════════════╝")
    print()

    # Open browser
    webbrowser.open(url)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n  Interview session ended.")
        server.shutdown()


if __name__ == "__main__":
    main()
